{
  "name": "@captra/api",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "tsc -b",
    "dev": "sops exec-env env.development.json 'node --watch src/index.ts | pino-pretty'",
    "start": "sops exec-env env.production.json 'node src/index.ts'",
    "dev:db:migrate": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate migrate'",
    "dev:db:watch": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate watch'",
    "dev:db:commit": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate commit'",
    "dev:db:uncommit": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate uncommit'",
    "dev:db:status": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate status'",
    "dev:db:reset": "sops exec-env env.development.json 'node ../../node_modules/.bin/graphile-migrate reset --erase'",
    "prod:db:migrate": "sops exec-env env.production.json 'node ../../node_modules/.bin/graphile-migrate migrate'",
    "test": "sops exec-env env.test.json 'node --test --import ./tests/setup.ts --test-concurrency=1 tests/**/*.test.ts'"
  },
  "dependencies": {
    "@captra/shared": "*",
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.3.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-koa": "^0.61.0",
    "@opentelemetry/instrumentation-pg": "^0.65.0",
    "@opentelemetry/instrumentation-pino": "^0.59.0",
    "@opentelemetry/instrumentation-undici": "^0.23.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@types/nodemailer": "^7.0.11",
    "close-with-grace": "^2.5.0",
    "graphile-worker": "^0.16.6",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "koa": "^3.1.2",
    "koa-helmet": "^9.0.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sql-template-strings": "^2.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/koa": "^3.0.1",
    "@types/koa__cors": "^5.0.1",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "graphile-migrate": "^1.4.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sql": "^0.19.2",
    "supertest": "^7.2.2",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  }
}
